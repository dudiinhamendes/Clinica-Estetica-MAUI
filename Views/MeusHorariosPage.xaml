<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SistemaClinica.Views.MeusHorariosPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush
            StartPoint="0,0"
            EndPoint="1,1">

            <GradientStop Color="#FFFDFC"
                    Offset="0"/>
            <GradientStop Color="#F6ECE7"
                    Offset="0.5"/>
            <GradientStop Color="#EEDDD4"
                    Offset="1"/>

        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>

        <VerticalStackLayout
            Padding="25"
            Spacing="20">

            <Grid
                ColumnDefinitions="*,140"
                Margin="0,10,0,10">

                <VerticalStackLayout
                    Grid.Column="0">

                    <Grid
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="15">
                        <Border
                            WidthRequest="45"
                            HeightRequest="45"
                            BackgroundColor="#FFF8F5"
                            Stroke="#D8C0B2"
                            StrokeShape="RoundRectangle 22.5">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OnVoltarClicked"/>
                            </Border.GestureRecognizers>

                            <Image
                                Source="seta_voltar.png"
                                WidthRequest="20"
                                HeightRequest="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>

                        </Border>

                        <!-- Título -->

                        <Label
                            Grid.Column="1"
                            Text="Meus Horários"
                            FontFamily="Georgia"
                            FontSize="34"
                            FontAttributes="Bold"
                            TextColor="#4A2419"
                            VerticalOptions="Center"/>

                    </Grid>

                    <!-- Subtítulo -->

                    <Label
                        Text="Confira seus horários agendados"
                        FontSize="18"
                        TextColor="#8B6F63"
                        Margin="60,10,0,0"/>

                </VerticalStackLayout>

                <Image
                    Grid.Column="1"
                    Source="flor_servico.png"
                    HeightRequest="130"
                    Aspect="AspectFit"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,-10,-15,0"
                    Opacity="0.45"/>

            </Grid>

            <!-- Card -->

            <CollectionView
                ItemsSource="{Binding MeusAgendamentos}"
                SelectionMode="None"
                Margin="0,10,0,0">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                            ItemSpacing="16"/>
                </CollectionView.ItemsLayout>


                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Margin="0,0,0,15"
                            BackgroundColor="#FFF8F5"
                            Stroke="#B8927E"
                            StrokeShape="RoundRectangle 22"
                            Padding="18">

                            <Grid
                                ColumnDefinitions="90,*"
                                ColumnSpacing="15">

                                <!-- Logo -->

                                <Border
                                    WidthRequest="80"
                                    HeightRequest="80"
                                    BackgroundColor="White"
                                    Stroke="#D8C0B2"
                                    StrokeShape="RoundRectangle 40"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Start">

                                    <Image
                                        Source="logo.png"
                                        WidthRequest="55"
                                        HeightRequest="55"
                                        Aspect="AspectFit"/>

                                </Border>

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Spacing="8">

                                    <Grid ColumnDefinitions="*,Auto">

                                        <Label
                                            Text="{Binding Nome_servico}"
                                            FontSize="22"
                                            CharacterSpacing="0.5"
                                            FontAttributes="Bold"
                                            TextColor="#4A2419"/>

                                        <Border
                                            Grid.Column="1"
                                            BackgroundColor="#F7EEE8"
                                            Stroke="#D8C0B2"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="10,5">

                                            <Label
                                                Text="{Binding Status}"
                                                FontSize="12"
                                                FontAttributes="Bold"
                                                TextColor="#8B6F63"/>

                                        </Border>

                                    </Grid>

                                    <BoxView
                                        HeightRequest="1"
                                        Color="#D8C0B2"
                                        Margin="0,8,0,5"/>

                                    <HorizontalStackLayout
                                        Spacing="8">

                                        <Image
                                            Source="perfil.png"
                                            WidthRequest="16"
                                            HeightRequest="16"/>

                                        <Label
                                            Text="{Binding Nome_funcionario}"
                                            FontSize="15"
                                            TextColor="#7A5A4D"/>

                                    </HorizontalStackLayout>


                                    <HorizontalStackLayout
                                        Spacing="8">

                                        <Image
                                            Source="agenda.png"
                                            WidthRequest="16"
                                            HeightRequest="16"/>

                                        <Label
                                            Text="{Binding Data_Horario, StringFormat='{0:dd/MM/yyyy}'}"
                                            FontSize="15"
                                            TextColor="#7A5A4D"/>

                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout
                                        Spacing="25">

                                        <HorizontalStackLayout
                                            Spacing="8">

                                            <Image
                                                Source="relogio.png"
                                                WidthRequest="16"
                                                HeightRequest="16"/>

                                            <Label
                                                Text="{Binding Data_Horario, StringFormat='{0:HH:mm}'}"
                                                FontSize="15"
                                                TextColor="#7A5A4D"/>

                                        </HorizontalStackLayout>

                                    </HorizontalStackLayout>


                                    <HorizontalStackLayout
                                        HorizontalOptions="End"
                                        Spacing="10"
                                        Margin="0,8,0,0">

                                        <Border
                                            BackgroundColor="#F7EEE8"
                                            Stroke="#B8927E"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="12,8">

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Tapped="OnEditarClicked"/>
                                            </Border.GestureRecognizers>

                                            <HorizontalStackLayout
                                                Spacing="6">

                                                <Image
                                                    Source="editar.png"
                                                    WidthRequest="16"
                                                    HeightRequest="16"/>

                                                <Label
                                                    Text="Editar"
                                                    FontAttributes="Bold"
                                                    TextColor="#4A2419"/>

                                            </HorizontalStackLayout>

                                        </Border>

                                        <Border
                                            BackgroundColor="#FDEAEA"
                                            Stroke="#D89A9A"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="12,8">

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Tapped="OnCancelarClicked"
                                                    CommandParameter="{Binding}"/>
                                            </Border.GestureRecognizers>

                                            <HorizontalStackLayout
                                                Spacing="6">

                                                <Image
                                                    Source="cancelar.png"
                                                    WidthRequest="16"
                                                    HeightRequest="16"/>

                                                <Label
                                                    Text="Cancelar"
                                                    FontAttributes="Bold"
                                                    TextColor="#A55A5A"/>

                                            </HorizontalStackLayout>

                                        </Border>

                                    </HorizontalStackLayout>

                                </VerticalStackLayout>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
