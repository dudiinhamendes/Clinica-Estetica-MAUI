<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SistemaClinica.Views.GerenciarAgendamentoPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush
            StartPoint="0,0"
            EndPoint="1,1">

            <GradientStop Color="#5A3125"
                          Offset="0"/>
            <GradientStop Color="#6B3D2E"
                          Offset="1"/>

        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>

        <ScrollView>

            <VerticalStackLayout
                Padding="25"
                Spacing="20">

                <Grid ColumnDefinitions="*,140"
                      Margin="0,10,0,10">

                    <VerticalStackLayout
                        Grid.Column="0">

                        <Grid
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="15">

                            <!-- Seta -->

                            <Border
                                WidthRequest="45"
                                HeightRequest="45"
                                BackgroundColor="#FFF8F5"
                                Stroke="#D8C0B2"
                                StrokeShape="RoundRectangle 22.5">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnVoltarAgendamentoClicked"/>
                                </Border.GestureRecognizers>

                                <Image
                                    Source="seta_voltar.png"
                                    WidthRequest="20"
                                    HeightRequest="20"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            </Border>

                            <!-- Título -->

                            <Label
                                Grid.Column="1"
                                Text="Gerenciar Agendamento"
                                FontFamily="Georgia"
                                FontSize="30"
                                FontAttributes="Bold"
                                TextColor="White"
                                VerticalTextAlignment="Center"/>

                        </Grid>

                        <!-- Subtítulo -->

                        <Label
                            Text="Cadastre e gerencie agendamento"
                            FontSize="14"
                            TextColor="#D8C0B2"
                            Margin="60,10,0,0"/>

                    </VerticalStackLayout>

                </Grid>

                <!-- Botão de novo agendamento -->

                <Border
                    BackgroundColor="#F2D6C5"
                    Stroke="#B8927E"
                    StrokeShape="RoundRectangle 20"
                    Padding="18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnNovoAgendamentoClicked"/>
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Spacing="10">

                        <Border
                            WidthRequest="45"
                            HeightRequest="45"
                            BackgroundColor="#FF644230"
                            StrokeShape="RoundRectangle 22.5">

                            <Image
                                Source="adicionar.png"
                                WidthRequest="20"
                                HeightRequest="20"/>
                        </Border>

                        <Label
                            Text="Novo Agendamento"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#4A2419"
                            FontFamily="Arial"
                            VerticalTextAlignment="Center"/>

                    </HorizontalStackLayout>

                </Border>

                <!-- Agendamento -->

                <CollectionView ItemsSource="{Binding Agendamentos}"
                                Margin="0,10,0,0">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="16"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="0,0,0,15"
                                BackgroundColor="#FFF8F5"
                                Stroke="#B8927E"
                                StrokeShape="RoundRectangle 22"
                                Padding="18">

                                <Grid
                                    ColumnDefinitions="90,*"
                                    ColumnSpacing="15">

                                    <!-- Logo -->

                                    <Border
                                        WidthRequest="80"
                                        HeightRequest="80"
                                        BackgroundColor="White"
                                        Stroke="#D8C0B2"
                                        StrokeShape="RoundRectangle 40"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Start">

                                        <Image
                                            Source="agenda.png"
                                            WidthRequest="55"
                                            HeightRequest="55"
                                            Aspect="AspectFit"/>

                                    </Border>


                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="8">

                                        <Grid ColumnDefinitions="*,Auto">

                                            <Label
                                                Text="{Binding Nome_servico}"
                                                FontSize="22"
                                                CharacterSpacing="0.5"
                                                FontAttributes="Bold"
                                                TextColor="#4A2419"/>

                                            <Border
                                                Grid.Column="1"
                                                BackgroundColor="#E8F5E9"
                                                Stroke="#4CAF50"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="10,5">

                                                <Label
                                                    Text="{Binding Status}"
                                                    FontSize="12"
                                                    FontAttributes="Bold"
                                                    TextColor="#2E7D32"/>

                                            </Border>

                                        </Grid>

                                        <BoxView
                                            HeightRequest="1"
                                            Color="#D8C0B2"
                                            Margin="0,8,0,5"/>

                                        <!-- Cliente -->

                                        <HorizontalStackLayout Spacing="8">

                                            <Image
                                                Source="usuario.png"
                                                WidthRequest="16"
                                                HeightRequest="16"/>

                                            <Label
                                                Text="{Binding Nome_cliente}"
                                                FontSize="15"
                                                TextColor="#7A5A4D"/>

                                        </HorizontalStackLayout>

                                        <!-- Funcionário -->

                                        <HorizontalStackLayout Spacing="8">

                                            <Image
                                                Source="perfil.png"
                                                WidthRequest="16"
                                                HeightRequest="16"/>

                                            <Label
                                                Text="{Binding Nome_funcionario}"
                                                FontSize="15"
                                                TextColor="#7A5A4D"/>

                                        </HorizontalStackLayout>

                                        <!-- Data -->

                                        <HorizontalStackLayout Spacing="8">

                                            <Image
                                                Source="agenda.png"
                                                WidthRequest="16"
                                                HeightRequest="16"/>

                                            <Label
                                                Text="{Binding Data_Horario, StringFormat='{0:dd/MM/yyyy}'}"
                                                FontSize="15"
                                                TextColor="#7A5A4D"/>

                                        </HorizontalStackLayout>

                                        <!-- Hora -->

                                        <HorizontalStackLayout Spacing="8">

                                            <Image
                                                Source="relogio.png"
                                                WidthRequest="16"
                                                HeightRequest="16"/>

                                            <Label
                                                Text="{Binding Data_Horario, StringFormat='{0:HH:mm}'}"
                                                FontSize="15"
                                                TextColor="#7A5A4D"/>

                                        </HorizontalStackLayout>

                                        <!-- Botões de editar e excluir -->

                                        <HorizontalStackLayout
                                            HorizontalOptions="End"
                                            Spacing="10"
                                            Margin="0,8,0,0">

                                            <Border
                                                BackgroundColor="#F7EEE8"
                                                Stroke="#B8927E"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="12,8">

                                                <Border.GestureRecognizers>

                                                    <TapGestureRecognizer
                                                        Tapped="OnEditarAgendamentoClicked"
                                                        CommandParameter="{Binding}"/>

                                                </Border.GestureRecognizers>

                                                <HorizontalStackLayout Spacing="6">

                                                    <Image
                                                        Source="editar.png"
                                                        WidthRequest="16"
                                                        HeightRequest="16"/>

                                                    <Label
                                                        Text="Editar"
                                                        FontAttributes="Bold"
                                                        TextColor="#4A2419"/>

                                                </HorizontalStackLayout>

                                            </Border>

                                            <Border
                                                BackgroundColor="#FDEAEA"
                                                Stroke="#D89A9A"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="12,8">

                                                <Border.GestureRecognizers>

                                                    <TapGestureRecognizer
                                                        Tapped="OnCancelarAgendamentoClicked"
                                                        CommandParameter="{Binding}"/>

                                                </Border.GestureRecognizers>

                                                <HorizontalStackLayout Spacing="6">

                                                    <Image
                                                        Source="cancelar.png"
                                                        WidthRequest="16"
                                                        HeightRequest="16"/>

                                                    <Label
                                                        Text="Excluir"
                                                        FontAttributes="Bold"
                                                        TextColor="#A55A5A"/>

                                                </HorizontalStackLayout>

                                            </Border>

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </ScrollView>

        <!-- Modal de novo agendamento -->

        <Grid
            x:Name="ModalNovoAgendamento"
            IsVisible="False"
            BackgroundColor="#80000000">

            <Grid
                VerticalOptions="Center"
                HorizontalOptions="Center">

                <Border
                    BackgroundColor="#FFF8F5"
                    Stroke="#D8C0B2"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 35"
                    Padding="8"
                    WidthRequest="380">

                    <Border
                        BackgroundColor="#FFF8F5"
                        Stroke="#E7CEC0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 30"
                        Padding="25">

                        <ScrollView
                            VerticalOptions="FillAndExpand"
                            MaximumHeightRequest="550">

                            <VerticalStackLayout
                                Spacing="20"
                                Padding="0,0,20,0">

                                <!-- Título -->

                                <Label
                                    Text="Novo&#10;Agendamento"
                                    FontSize="28"
                                    FontFamily="Georgia"
                                    FontAttributes="Bold"
                                    TextColor="#4A2419"
                                    HorizontalTextAlignment="Center"
                                    HorizontalOptions="Center"
                                    Margin="0,0,0,5"/>

                                <!-- Linha decorativa -->

                                <Grid
                                    ColumnDefinitions="*,Auto,*"
                                    Margin="20,0">

                                    <BoxView
                                        HeightRequest="1"
                                        Color="#D8C0B2"
                                        VerticalOptions="Center"/>

                                    <Label
                                        Grid.Column="1"
                                        Text="✦"
                                        FontSize="18"
                                        Margin="15,0"
                                        TextColor="#B8927E"/>

                                    <BoxView
                                        Grid.Column="2"
                                        HeightRequest="1"
                                        Color="#D8C0B2"
                                        VerticalOptions="Center"/>

                                </Grid>

                                <!-- Picker Cliente -->

                                <VerticalStackLayout Spacing="4">

                                    <Label
                                        Text="Cliente"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#706259"
                                        Margin="5,0"/>

                                    <Border
                                        Stroke="#D8C0B2"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 18"
                                        BackgroundColor="#F7EEE8"
                                        Padding="15,0">

                                        <Picker
                                            x:Name="PickerCliente"
                                            TextColor="#4A2419"
                                            BackgroundColor="Transparent"
                                            HorizontalTextAlignment="Center">

                                            <Picker.Items>
                                                <x:String>Bianca Ferreira</x:String>
                                                <x:String>Gabriela Souza</x:String>
                                                <x:String>Paula Fernandes</x:String>
                                                <x:String>Eduarda Mendes</x:String>

                                            </Picker.Items>

                                        </Picker>

                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="4">

                                    <!-- Picker Funcionário -->

                                    <Label
                                        Text="Funcionário"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#706259"
                                        Margin="5,0"/>

                                    <Border
                                        Stroke="#D8C0B2"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 18"
                                        BackgroundColor="#F7EEE8"
                                        Padding="15,0">

                                        <Picker
                                            x:Name="PickerFuncionario"
                                            ItemsSource="{Binding Funcionarios}"
                                            ItemDisplayBinding="{Binding Nome_funcionario}"
                                            SelectedIndexChanged="PickerFuncionario_SelectedIndexChanged"
                                            TextColor="#4A2419"
                                            BackgroundColor="Transparent"
                                            HorizontalTextAlignment="Center"/>

                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="4">

                                    <!-- Picker Serviço -->

                                    <Label
                                        Text="Serviço"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#706259"
                                        Margin="5,0"/>

                                    <Border
                                        Stroke="#D8C0B2"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 18"
                                        BackgroundColor="#F7EEE8"
                                        Padding="15,0">

                                        <Picker
                                            x:Name="PickerServico"
                                            IsEnabled="False"
                                            ItemsSource="{Binding Servicos}"
                                            ItemDisplayBinding="{Binding Nome_servico}"
                                            TextColor="#4A2419"
                                            BackgroundColor="Transparent"
                                            HorizontalTextAlignment="Center"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- DatePicker -->

                                <VerticalStackLayout Spacing="4">

                                    <Label
                                        Text="Data"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#706259"
                                        Margin="5,0"/>

                                    <Border
                                        BackgroundColor="#F7EEE8"
                                        Stroke="#D8C0B2"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="15,0">

                                        <DatePicker
                                            x:Name="DateAgendamento"
                                            HeightRequest="45"
                                            WidthRequest="150"
                                            Format="dd/MM/yyyy"
                                            TextColor="#4A2419"
                                            BackgroundColor="Transparent"
                                            HorizontalOptions="Center"/>

                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="4">

                                    <!-- TimePicker -->

                                    <Label
                                        Text="Horário"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#7A5A4D"
                                        Margin="5,15,0,8"/>

                                    <Border
                                        Stroke="#D8C0B2"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 18"
                                        BackgroundColor="#F7EEE8"
                                        Padding="15,5">

                                        <Grid ColumnDefinitions="*, Auto, *">

                                            <TimePicker
                                                Grid.Column="1"
                                                x:Name="TimeAgendamento"
                                                HeightRequest="45"
                                                WidthRequest="160"
                                                TextColor="#4A2419"
                                                BackgroundColor="Transparent"/>
                                        </Grid>

                                    </Border>

                                </VerticalStackLayout>

                                <!-- Status -->

                                <VerticalStackLayout Spacing="4">
                                    <Label
                                        Text="Status"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#706259"
                                        Margin="5,0"/>

                                    <Border
                                        Stroke="#D8C0B2"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 18"
                                        BackgroundColor="#F7EEE8"
                                        Padding="15,0">

                                        <Picker
                                            x:Name="PickerStatus"
                                            TextColor="#4A2419"
                                            BackgroundColor="Transparent"
                                            HorizontalTextAlignment="Center">

                                            <Picker.Items>
                                                <x:String>Pendente</x:String>
                                                <x:String>Concluído</x:String>

                                            </Picker.Items>
                                        </Picker>

                                    </Border>
                                </VerticalStackLayout>

                                <!-- Erro -->

                                <Label
                                    x:Name="LabelErro"
                                    TextColor="Red"
                                    FontSize="13"
                                    IsVisible="False"
                                    HorizontalOptions="Center"/>

                                <!-- Botões de editar e excluir -->

                                <Grid
                                    ColumnDefinitions="*,*"
                                    ColumnSpacing="15"
                                    Margin="0,10,0,0">

                                    <Button
                                        Grid.Column="0"
                                        Text="Cancelar"
                                        BackgroundColor="#4A2419"
                                        BorderColor="#65FFA65E"
                                        TextColor="White"
                                        CornerRadius="20"
                                        HeightRequest="50"
                                        FontAttributes="Bold"
                                        Clicked="OnCancelarModalAgendamentoClicked"/>

                                    <Button
                                        Grid.Column="1"
                                        Text="Salvar"
                                        BackgroundColor="#4A2419"
                                        BorderColor="#65FFA65E"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        CornerRadius="20"
                                        HeightRequest="50"
                                        Clicked="OnSalvarAgendamentoClicked"/>

                                </Grid>

                            </VerticalStackLayout>

                        </ScrollView>

                    </Border>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
