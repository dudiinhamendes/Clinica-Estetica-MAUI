<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SistemaClinica.Views.HomeAdminPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush
            StartPoint="0,0"
            EndPoint="1,1">

            <GradientStop Color="#3E1F16"
                    Offset="0"/>
            <GradientStop Color="#4A2419"
                    Offset="0.5"/>
            <GradientStop Color="#5A3125"
                    Offset="1"/>

        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>

        <VerticalStackLayout
            Padding="25"
            Spacing="20">

            <!-- Logo -->

            <Image
                Source="logo_admin.png"
                WidthRequest="180"
                HeightRequest="180"
                HorizontalOptions="Center"/>

            <!-- Título -->

            <VerticalStackLayout
                Spacing="5"
                Margin="0,-30,0,0">

                <Label
                    Text="Painel Administrativo"
                    FontSize="28"
                    FontFamily="Georgia"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center"/>

                <Grid
                    ColumnDefinitions="*,Auto,*"
                    Margin="0,5,0,5">

                    <BoxView
                        Grid.Column="0"
                        HeightRequest="1"
                        Color="#D8C0B2"
                        VerticalOptions="Center"/>

                    <Label
                        Grid.Column="1"
                        Text="✦"
                        FontSize="16"
                        TextColor="#D8C0B2"
                        Margin="10,0"/>

                    <BoxView
                        Grid.Column="2"
                        HeightRequest="1"
                        Color="#D8C0B2"
                        VerticalOptions="Center"/>

                </Grid>

                <Label
                    Text="Gerencie sua clínica com eficiência"
                    FontSize="18"
                    TextColor="#F2D6C5"
                    HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>

            <Grid
                Margin="0,10,0,0"
                ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="15"
                RowSpacing="15">

                <!-- Serviços -->

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    BackgroundColor="#F2D6C5"
                    Stroke="#B46B44"
                    StrokeShape="RoundRectangle 25"
                    Padding="15">

                    <HorizontalStackLayout Spacing="15">

                        <Border
                            WidthRequest="70"
                            HeightRequest="70"
                            Stroke="#B8927E"
                            StrokeThickness="2"
                            BackgroundColor="#FFF8F5"
                            StrokeShape="RoundRectangle 35">

                            <Image
                                Source="servicos.png"
                                WidthRequest="32"
                                HeightRequest="32"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>

                        </Border>

                        <VerticalStackLayout>

                            <Label
                                x:name="LabelTotalServicos"
                                Text="{Binding TotalServicos}"
                                FontSize="34"
                                FontAttributes="Bold"
                                TextColor="#4A2419"/>

                            <Label
                                Text="SERVIÇOS"
                                FontFamily="Georgia"
                                FontSize="16"
                                FontAttributes="Bold"
                                CharacterSpacing="0.5"
                                TextColor="#4A2419"/>

                            <Label
                                Text="Cadastrados"
                                FontSize="12"
                                FontAttributes="Italic"
                                TextColor="#4A2419"/>

                        </VerticalStackLayout>

                    </HorizontalStackLayout>

                </Border>

                <!-- Funcionários -->

                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    BackgroundColor="#F2D6C5"
                    Stroke="#B46B44"
                    StrokeShape="RoundRectangle 25"
                    Padding="15">

                    <HorizontalStackLayout Spacing="15">

                        <Border
                            WidthRequest="70"
                            HeightRequest="70"
                            Stroke="#B8927E"
                            StrokeThickness="2"
                            BackgroundColor="#FFF8F5"
                            StrokeShape="RoundRectangle 35">

                            <Image
                                Source="perfil.png"
                                WidthRequest="32"
                                HeightRequest="32"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>

                        </Border>

                        <VerticalStackLayout>

                            <Label
                                x:name="LabelTotalFuncionarios"
                                Text="{Binding TotalFuncionarios}"
                                FontSize="34"
                                FontAttributes="Bold"
                                TextColor="#4A2419"/>

                            <Label
                                Text="FUNCIONÁRIOS"
                                FontFamily="Georgia"
                                FontSize="16"
                                CharacterSpacing="0.5"
                                FontAttributes="Bold"
                                TextColor="#4A2419"/>

                            <Label
                                Text="Cadastrados"
                                FontSize="12"
                                FontAttributes="Italic"
                                TextColor="#4A2419"/>

                        </VerticalStackLayout>

                    </HorizontalStackLayout>

                </Border>

                <!-- Agendamentos -->

                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    BackgroundColor="#F2D6C5"
                    Stroke="#B46B44"
                    StrokeShape="RoundRectangle 25"
                    Padding="15">

                    <HorizontalStackLayout Spacing="15">

                        <Border
                            WidthRequest="70"
                            HeightRequest="70"
                            Stroke="#B8927E"
                            StrokeThickness="2"
                            BackgroundColor="#FFF8F5"
                            StrokeShape="RoundRectangle 35">

                            <Image
                                Source="agenda.png"
                                WidthRequest="32"
                                HeightRequest="32"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>

                        </Border>

                        <VerticalStackLayout>

                            <Label
                                x:Name="LabelTotalAgendamentos"
                                Text="{Binding TotalAgendamentos}"
                                FontSize="34"
                                FontAttributes="Bold"
                                TextColor="#4A2419"/>

                            <Label
                                Text="AGENDAMENTOS"
                                FontFamily="Georgia"
                                FontSize="16"
                                FontAttributes="Bold"
                                CharacterSpacing="0.5"
                                TextColor="#4A2419"/>

                            <Label
                                Text="Para hoje"
                                FontSize="12"
                                FontAttributes="Italic"
                                TextColor="#4A2419"/>

                        </VerticalStackLayout>

                    </HorizontalStackLayout>

                </Border>

                <!-- Usuários -->

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    BackgroundColor="#F2D6C5"
                    Stroke="#B46B44"
                    StrokeShape="RoundRectangle 25"
                    Padding="15">

                    <HorizontalStackLayout Spacing="15">

                        <Border
                            WidthRequest="70"
                            HeightRequest="70"
                            Stroke="#B8927E"
                            StrokeThickness="2"
                            BackgroundColor="#FFF8F5"
                            StrokeShape="RoundRectangle 35">

                            <Image
                                Source="usuario.png"
                                WidthRequest="32"
                                HeightRequest="32"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>

                        </Border>

                        <VerticalStackLayout>

                            <Label
                                Text="4"
                                FontSize="34"
                                FontAttributes="Bold"
                                TextColor="#4A2419"/>

                            <Label
                                Text="USUÁRIOS"
                                FontFamily="Georgia"
                                FontSize="16"
                                CharacterSpacing="0.5"
                                FontAttributes="Bold"
                                TextColor="#4A2419"/>

                            <Label
                                Text="Cadastrados"
                                FontSize="12"
                                FontAttributes="Italic"
                                TextColor="#4A2419"/>

                        </VerticalStackLayout>

                    </HorizontalStackLayout>

                </Border>

            </Grid>

            <!-- Acesso rápido -->

            <VerticalStackLayout
                Spacing="3">

                <Label
                    Text="Central Administrativa"
                    FontFamily="Georgia"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="White"/>

                <Label
                    Text="Gerencie todos os setores da clínica"
                    FontSize="13"
                    TextColor="#D8C0B2"/>

            </VerticalStackLayout>

            <!-- Serviços -->

            <Border
                BackgroundColor="#FFF8F5"
                Stroke="#D8C0B2"
                StrokeShape="RoundRectangle 18"
                Padding="15">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnGerenciarServicoClicked"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <Border
                        WidthRequest="45"
                        HeightRequest="45"
                        BackgroundColor="#F2D6C5"
                        Stroke="#B8927E"
                        StrokeShape="RoundRectangle 22.5">

                        <Image
                            Source="servicos.png"
                            WidthRequest="20"
                            HeightRequest="20"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                    </Border>

                    <Label
                        Grid.Column="1"
                        Margin="15,0"
                        Text="Gerenciar Serviços"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#4A2419"
                        VerticalTextAlignment="Center"/>

                    <Image
                        Grid.Column="2"
                        Source="seta_admin.png"
                        WidthRequest="16"
                        HeightRequest="16"
                        VerticalOptions="Center"/>

                </Grid>

            </Border>

            <!-- Funcionários -->

            <Border
                BackgroundColor="#FFF8F5"
                Stroke="#D8C0B2"
                StrokeShape="RoundRectangle 18"
                Padding="15">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnGerenciarFuncionarioClicked"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <Border
                        WidthRequest="45"
                        HeightRequest="45"
                        BackgroundColor="#F2D6C5"
                        Stroke="#B8927E"
                        StrokeShape="RoundRectangle 22.5">

                        <Image
                            Source="perfil.png"
                            WidthRequest="20"
                            HeightRequest="20"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                    </Border>

                    <Label
                        Grid.Column="1"
                        Margin="15,0"
                        Text="Gerenciar Funcionários"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#4A2419"
                        VerticalTextAlignment="Center"/>

                    <Image
                        Grid.Column="2"
                        Source="seta_admin.png"
                        WidthRequest="16"
                        HeightRequest="16"
                        VerticalOptions="Center"/>

                </Grid>

            </Border>

            <!-- Agendamentos -->

            <Border
                BackgroundColor="#FFF8F5"
                Stroke="#D8C0B2"
                StrokeShape="RoundRectangle 18"
                Padding="15">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnGerenciarAgendamentoClicked"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <Border
                        WidthRequest="45"
                        HeightRequest="45"
                        BackgroundColor="#F2D6C5"
                        Stroke="#B8927E"
                        StrokeShape="RoundRectangle 22.5">

                        <Image
                            Source="agenda.png"
                            WidthRequest="20"
                            HeightRequest="20"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                    </Border>

                    <Label
                        Grid.Column="1"
                        Margin="15,0"
                        Text="Gerenciar Agendamentos"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#4A2419"
                        VerticalTextAlignment="Center"/>

                    <Image
                        Grid.Column="2"
                        Source="seta_admin.png"
                        WidthRequest="16"
                        HeightRequest="16"
                        VerticalOptions="Center"/>

                </Grid>

            </Border>

            <!-- Usuários -->

            <Border
                BackgroundColor="#FFF8F5"
                Stroke="#D8C0B2"
                StrokeShape="RoundRectangle 18"
                Padding="15">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnGerenciarUsuarioClicked"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <Border
                        WidthRequest="45"
                        HeightRequest="45"
                        BackgroundColor="#F2D6C5"
                        Stroke="#B8927E"
                        StrokeShape="RoundRectangle 22.5">

                        <Image
                            Source="usuario.png"
                            WidthRequest="20"
                            HeightRequest="20"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                    </Border>

                    <Label
                        Grid.Column="1"
                        Margin="15,0"
                        Text="Gerenciar Usuários"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#4A2419"
                        VerticalTextAlignment="Center"/>

                    <Image
                        Grid.Column="2"
                        Source="seta_admin.png"
                        WidthRequest="16"
                        HeightRequest="16"
                        VerticalOptions="Center"/>

                </Grid>

            </Border>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
