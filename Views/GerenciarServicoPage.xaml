<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SistemaClinica.Views.GerenciarServicoPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush
            StartPoint="0,0"
            EndPoint="1,1">

            <GradientStop Color="#5A3125"
                    Offset="0"/>
            <GradientStop Color="#6B3D2E"
                    Offset="1"/>

        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>
        <ScrollView>

            <VerticalStackLayout
                Padding="25"
                Spacing="20">


                <Grid ColumnDefinitions="*,140"
                      Margin="0,10,0,10">

                    <VerticalStackLayout
                        Grid.Column="0">

                        <Grid
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="15">


                            <!-- Seta -->

                            <Border
                                WidthRequest="45"
                                HeightRequest="45"
                                BackgroundColor="#FFF8F5"
                                Stroke="#D8C0B2"
                                StrokeShape="RoundRectangle 22.5">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnVoltarServicoClicked"/>
                                </Border.GestureRecognizers>

                                <Image
                                    Source="seta_voltar.png"
                                    WidthRequest="20"
                                    HeightRequest="20"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            </Border>

                            <!-- Título -->

                            <Label
                                Grid.Column="1"
                                Text="Gerenciar Serviços"
                                FontFamily="Georgia"
                                FontSize="30"
                                FontAttributes="Bold"
                                TextColor="White"
                                VerticalTextAlignment="Center"/>

                        </Grid>

                        <!-- Subtítulo -->

                        <Label
                            Text="Cadastre e gerencie procedimentos"
                            FontSize="14"
                            TextColor="#D8C0B2"
                            Margin="60,10,0,0"/>

                    </VerticalStackLayout>

                </Grid>

                <!-- Botão de novo serviço -->

                <Border
                    BackgroundColor="#F2D6C5"
                    Stroke="#B8927E"
                    StrokeShape="RoundRectangle 20"
                    Padding="18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Tapped="OnNovoServicoClicked"/>
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Spacing="10">

                        <Border
                            WidthRequest="45"
                            HeightRequest="45"
                            BackgroundColor="#FF644230"
                            StrokeShape="RoundRectangle 22.5">

                            <Image
                                Source="adicionar.png"
                                WidthRequest="20"
                                HeightRequest="20"/>
                        </Border>

                        <Label
                            Text="Novo Serviço"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#4A2419"
                            FontFamily="Arial"
                            VerticalTextAlignment="Center"/>

                    </HorizontalStackLayout>

                </Border>

                <!-- Serviço -->

                <CollectionView ItemsSource="{Binding Servicos}"
                                Margin="0,10,0,0">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                ItemSpacing="16"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="0,0,0,15"
                                BackgroundColor="#FFF8F5"
                                Stroke="#B8927E"
                                StrokeShape="RoundRectangle 22"
                                Padding="18">

                                <Grid
                                    ColumnDefinitions="90,*"
                                    ColumnSpacing="15">

                                    <Border
                                        WidthRequest="80"
                                        HeightRequest="80"
                                        BackgroundColor="White"
                                        Stroke="#D8C0B2"
                                        StrokeShape="RoundRectangle 40"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Start">

                                        <Image
                                            Source="logo.png"
                                            WidthRequest="55"
                                            HeightRequest="55"
                                            Aspect="AspectFit"/>

                                    </Border>

                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="8">

                                        <!-- Nome -->

                                        <Grid ColumnDefinitions="*,Auto">

                                            <Label
                                                Text="{Binding Nome_servico}"
                                                FontSize="22"
                                                CharacterSpacing="0.5"
                                                FontAttributes="Bold"
                                                TextColor="#4A2419"/>

                                        </Grid>

                                        <BoxView
                                            HeightRequest="1"
                                            Color="#D8C0B2"
                                            Margin="0,8,0,5"/>

                                        <!-- Duração + valor -->

                                        <VerticalStackLayout
                                            Spacing="5">

                                            <HorizontalStackLayout
                                                Spacing="8">

                                                <Image
                                                    Source="relogio.png"
                                                    WidthRequest="16"
                                                    HeightRequest="16"/>

                                                <Label
                                                    Text="{Binding Duracao, StringFormat='{}{0} minutos'}"
                                                    FontSize="15"
                                                    TextColor="#7A5A4D"/>

                                            </HorizontalStackLayout>

                                            <HorizontalStackLayout
                                                Spacing="8">

                                                <Image
                                                    Source="dinheiro.png"
                                                    WidthRequest="16"
                                                    HeightRequest="16"/>

                                                <Label
                                                    Text="{Binding Preco, StringFormat='R$ {0:F2}'}"
                                                    FontSize="15"
                                                    TextColor="#7A5A4D"/>

                                            </HorizontalStackLayout>

                                        </VerticalStackLayout>

                                        <!-- Botões de editar e excluir -->

                                        <HorizontalStackLayout
                                            HorizontalOptions="End"
                                            Spacing="10"
                                            Margin="0,8,0,0">

                                            <Border
                                                BackgroundColor="#F7EEE8"
                                                Stroke="#B8927E"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="12,8">

                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Tapped="OnEditarServicoClicked"/>
                                                </Border.GestureRecognizers>

                                                <HorizontalStackLayout
                                                    Spacing="6">

                                                    <Image
                                                        Source="editar.png"
                                                        WidthRequest="16"
                                                        HeightRequest="16"/>

                                                    <Label
                                                        Text="Editar"
                                                        FontAttributes="Bold"
                                                        TextColor="#4A2419"/>

                                                </HorizontalStackLayout>

                                            </Border>

                                            <Border
                                                BackgroundColor="#FDEAEA"
                                                Stroke="#D89A9A"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="12,8">

                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Tapped="OnCancelarServicoClicked"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>

                                                <HorizontalStackLayout
                                                    Spacing="6">

                                                    <Image
                                                        Source="cancelar.png"
                                                        WidthRequest="16"
                                                        HeightRequest="16"/>

                                                    <Label
                                                        Text="Excluir"
                                                        FontAttributes="Bold"
                                                        TextColor="#A55A5A"/>

                                                </HorizontalStackLayout>

                                            </Border>

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </ScrollView>

        <!-- Modal de novo serviço -->

        <Grid
            x:Name="ModalNovoServico"
            IsVisible="False"
            BackgroundColor="#80000000">

            <Grid
                VerticalOptions="Center"
                HorizontalOptions="Center">

                <Border
                    BackgroundColor="#FFF8F5"
                    Stroke="#D8C0B2"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 35"
                    Padding="8"
                    WidthRequest="380">

                    <Border
                        BackgroundColor="#FFF8F5"
                        Stroke="#E7CEC0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 30"
                        Padding="25">

                        <ScrollView
                            VerticalOptions="FillAndExpand"
                            MaximumHeightRequest="550"
                            VerticalScrollBarVisibility="Never">

                            <VerticalStackLayout
                                Spacing="20"
                                Padding="0,0,20,0">

                                <!-- Título -->

                                <Label
                                    Text="Novo&#10;Serviço"
                                    FontFamily="Georgia"
                                    FontSize="34"
                                    FontAttributes="Bold"
                                    HorizontalTextAlignment="Center"
                                    HorizontalOptions="Center"
                                    TextColor="#4A2419"/>

                                <!-- Linha decorativa -->

                                <Grid
                                    ColumnDefinitions="*,Auto,*"
                                    Margin="20,15,20,20">

                                    <BoxView
                                        HeightRequest="1"
                                        Color="#D8C0B2"
                                        VerticalOptions="Center"/>

                                    <Label
                                        Grid.Column="1"
                                        Text="✦"
                                        FontSize="18"
                                        Margin="15,0"
                                        TextColor="#B8927E"/>

                                    <BoxView
                                        Grid.Column="2"
                                        HeightRequest="1"
                                        Color="#D8C0B2"
                                        VerticalOptions="Center"/>

                                </Grid>

                                <!-- Nome -->

                                <VerticalStackLayout
                                    Spacing="4"
                                    Margin="0,0,0,15">

                                    <Label
                                        Text="Nome"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#7A5A4D"
                                        Margin="5,5,0,4"/>

                                    <Border
                                        BackgroundColor="#FFFDFC"
                                        Stroke="#D8C0B2"
                                        StrokeShape="RoundRectangle 18">

                                        <Entry
                                            x:Name="EntryNomeServico"
                                            Placeholder="Digite o nome"
                                            TextColor="#4A2419"
                                            PlaceholderColor="#8A8A8A"
                                            Margin="15,0"/>

                                    </Border>
                                </VerticalStackLayout>

                                <!-- Valor -->

                                <VerticalStackLayout
                                    Spacing="4"
                                    Margin="0,0,0,15">

                                    <Label
                                        Text="Valor"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#7A5A4D"
                                        Margin="5,5,0,4"/>

                                    <Border
                                        BackgroundColor="#FFFDFC"
                                        Stroke="#D8C0B2"
                                        StrokeShape="RoundRectangle 18">

                                        <Entry
                                            x:Name="EntryValorServico"
                                            Placeholder="Digite o valor"
                                            Keyboard="Numeric"
                                            TextColor="#4A2419"
                                            PlaceholderColor="#8A8A8A"
                                            Margin="15,0"/>

                                    </Border>
                                </VerticalStackLayout>


                                <!-- Duração -->

                                <VerticalStackLayout
                                    Spacing="4"
                                    Margin="0,0,0,15">

                                    <Label
                                        Text="Duração"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="#7A5A4D"
                                        Margin="5,5,0,4"/>

                                    <Border
                                        BackgroundColor="#FFFDFC"
                                        Stroke="#D8C0B2"
                                        StrokeShape="RoundRectangle 18">

                                        <Entry
                                            x:Name="EntryDuracaoServico"
                                            Placeholder="Digite a duração"
                                            Keyboard="Numeric"
                                            TextColor="#4A2419"
                                            PlaceholderColor="#8A8A8A"
                                            Margin="15,0"/>

                                    </Border>
                                </VerticalStackLayout>


                                <!-- Erro -->

                                <Label
                                    x:Name="LabelErro"
                                    TextColor="Red"
                                    FontSize="13"
                                    IsVisible="False"
                                    HorizontalOptions="Center"/>

                                <!-- Botões de cancelar e salvar -->

                                <Grid
                                    ColumnDefinitions="*,*"
                                    ColumnSpacing="15"
                                    Margin="0,10,0,0">

                                    <Button
                                        Grid.Column="0"
                                        Text="Cancelar"
                                        BackgroundColor="#4A2419"
                                        BorderColor="#65FFA65E"
                                        TextColor="White"
                                        CornerRadius="20"
                                        HeightRequest="55"
                                        FontAttributes="Bold"
                                        Clicked="OnCancelarModalClicked"/>

                                    <Button
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Text="Salvar"
                                        BackgroundColor="#4A2419"
                                        BorderColor="#65FFA65E"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        CornerRadius="18"
                                        HeightRequest="55"
                                        Clicked="OnSalvarServicoClicked"/>

                                </Grid>

                            </VerticalStackLayout>

                        </ScrollView>

                    </Border>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
